# =============================================================================
# IMPORTANT: Copy this file to .env and fill in your real credentials
#   cp .env.example .env
# 
# The .env file is gitignored and will NOT be committed to the repository.
# =============================================================================

# Azure OpenAI Configuration (Required)
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Azure OpenAI Options (Optional)
# TEMPERATURE=0.7
# MAX_TOKENS=1000

# Movie Data Source (Optional)
# MOVIE_FINDER_MODE: auto (default), tmdb, or stub
#   - auto: Uses TMDB if API key is set, otherwise stub data
#   - tmdb: Always uses TMDB (requires TMDB_API_KEY)
#   - stub: Always uses built-in stub data (no external calls)
# MOVIE_FINDER_MODE=auto
# TMDB_API_KEY=your-tmdb-api-key-here

# Logging (Optional)
# LOG_LEVEL=INFO

# LangSmith Observability (Optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key-here
# LANGCHAIN_PROJECT=movie-night-assistant
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
